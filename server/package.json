{
  "name": "taskorbit-server",
  "version": "1.0.0",
  "description": "Backend API for TaskOrbit",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "init-db": "node init-db.js",
    "migrate:dev": "node init-db.js",
    "migrate:prod": "node init-db.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "collectCoverageFrom": [
      "modules/proyectos/**/*.js",
      "modules/tareas/**/*.js",
      "modules/notificaciones/**/*.js",
      "utils/validators.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 20,
        "functions": 30,
        "lines": 25,
        "statements": 25
      }
    }
  }
}
